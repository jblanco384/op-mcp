# GRC MCP Server Configuration
#
# Quick Start:
#   - For minimal setup (on-premises or IBM Cloud HOSTED): Use .env.example.minimal.basic
#   - For minimal setup (IBM Cloud SaaS, MCSP, or CP4D): Use .env.example.minimal.bearer
#   - For detailed comments: See .env.example.full
#   - For comprehensive docs: See docs/CONFIGURATION_DEFAULTS.md

# ============================================================================
# MANDATORY SETTINGS
# ============================================================================

OPENPAGES_BASE_URL=https://your-openpages-instance.com/openpages
OPENPAGES_AUTHENTICATION_TYPE=basic

# Basic Auth (required if OPENPAGES_AUTHENTICATION_TYPE=basic)
OPENPAGES_USERNAME=itdirector
OPENPAGES_PASSWORD=

# Bearer Auth (required if OPENPAGES_AUTHENTICATION_TYPE=bearer)
OPENPAGES_AUTHENTICATION_URL=
OPENPAGES_APIKEY=

# CP4D (required for CP4D deployments)
OPENPAGES_INSTANCE_NAME=

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================

# Server
APP_NAME=grc-mcp-server
DEBUG=false
SERVER_MODE=remote
HOST=0.0.0.0
PORT=8000

# SSL
SSL_VERIFY=true

# HTTP
HTTP_MAX_CONNECTIONS=20

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/grc-mcp.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Observability
OBSERVABILITY_ENABLED=false
METRICS_ENABLED=false
TRACING_ENABLED=false
OTLP_ENDPOINT=
CONSOLE_TRACING=false

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# Object Types
OBJECT_TYPES_CONFIG_PATH=src/app/config/object_types.json

# Authentication
AUTH_ENABLED=true

# Currency
DEFAULT_CURRENCY=USD

# Schema Caching
SCHEMA_CACHE_MAX_SIZE=20
SCHEMA_CACHE_TTL=3600
ENABLE_MINIMAL_SCHEMA_MODE=true
CACHE_QUERY_EXAMPLES=true

# MCP Sessions
MCP_SESSION_ENFORCEMENT=false
MCP_SESSION_TTL=3600
MCP_SESSION_MAX_COUNT=1000
MCP_SESSION_CLEANUP_INTERVAL=300
